{
  "manifest_version": 3,
  "name": "Fandom Fixer",
  "version": "1.0.1",

  "description": "Makes fandom somewhat usable",

  "permissions": ["webRequest", "webRequestBlocking", "scripting"],

  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": ["none"]
      },
      "id": "fandomfixer@net.opensourcefreak"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["injector.js"],
      "matches": ["*://*.fandom.com/*"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["*://*.fandom.com/wiki/*", "*://*.fandom.com/*/wiki/*"],
      "js": ["postload.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.fandom.com/wiki/*", "*://*.fandom.com/*/wiki/*"],
      "js": ["preload.js"],
      "run_at": "document_start"
    }
  ],

  "background": {
    "scripts": ["background.js"]
  }
}
